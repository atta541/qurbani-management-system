// ============================================================
// Qurbani Management System — Final Prisma Schema
// Pakistan / Masjid Qurbani — Single Masjid
// ============================================================
//
// PAYAS RULE (Islamic):
//   Goat  → 1 portion,  4 payas
//   Cow   → 7 portions, 4 payas
//   Camel → 14 portions, 4 payas
//
//   Each payas belongs to ONE portion — 1 portion = 1 payas.
//   Only the first 4 customers (per animal) who want payas get one.
//   Portions 5, 6, 7 of a cow NEVER get payas — exhausted already.
//   First come, first served within each time slot.
//
// KEY SCHEMA DECISIONS:
//   - Pool-based: no individual animal records — admin sets totals.
//   - AnimalConfig.id used as FK (not enum kind) — safe & conventional.
//   - TimeSlot tracks totalPayas / bookedPayas (not "sets") — corrected model.
//   - PaymentAttempt child table for full audit trail on payment rejections.
//   - Notification.scheduledFor for queued reminder jobs.
//   - Booking.hissaIdentifier for which hissa numbers the customer owns.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

/// The four animal variants supported in Islamic Qurbani.
/// Cow split into MALE / FEMALE — may have different pricing.
enum AnimalKind {
  GOAT
  COW_MALE
  COW_FEMALE
  CAMEL
}

/// The three days of Eid-ul-Adha.
enum EidDay {
  DAY_1
  DAY_2
  DAY_3
}

/// Full lifecycle of a booking.
enum BookingStatus {
  DRAFT           // Customer started but did not submit yet
  PENDING         // Submitted, awaiting payment
  PAYMENT_PENDING // Payment proof uploaded, awaiting admin approval
  CONFIRMED       // Payment approved — booking locked in
  CANCELLED       // Cancelled by admin or customer
  NO_SHOW         // Did not arrive at assigned time slot
  DISTRIBUTED     // Meat successfully handed over
}

/// Payment lifecycle.
enum PaymentStatus {
  UNPAID           // No payment received yet
  PARTIALLY_PAID   // Advance received (if allowed by admin)
  SUBMITTED        // Proof uploaded by customer, pending review
  APPROVED         // Admin confirmed the payment
  REJECTED         // Proof rejected — customer must resubmit
  REFUNDED         // Amount returned after cancellation
}

/// Supported payment channels in Pakistan.
enum PaymentMethod {
  CASH
  BANK_TRANSFER
  EASYPAISA
  JAZZCASH
  SADAPAY
  NAYAPAY
  OTHER
}

/// Channel used to send a notification.
enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
}

/// All notification event types in the system.
enum NotificationType {
  BOOKING_CREATED
  BOOKING_CONFIRMED
  PAYMENT_SUBMITTED
  PAYMENT_APPROVED
  PAYMENT_REJECTED
  EID_REMINDER        // Scheduled ~2 days before Eid
  SLOT_REMINDER       // Scheduled on Eid morning with customer's time slot
  DISTRIBUTION_READY  // Meat is ready for collection
  BOOKING_CANCELLED
  YEARLY_OUTREACH     // Re-engagement before next Eid season
}

/// Delivery status of a sent notification.
enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

/// State of the QR/PDF slip issued to a customer.
enum SlipStatus {
  VALID     // Generated, not yet used
  USED      // Scanned at distribution point
  CANCELLED // Booking was cancelled
}

// ============================================================
// MODELS
// ============================================================

// ─────────────────────────────────────────────
// YEAR — one record per Eid season.
// Admin activates exactly one year at a time.
// ─────────────────────────────────────────────
model Year {
  id        Int      @id @default(autoincrement())
  year      Int      @unique                         // e.g. 2026
  label     String                                   // "Eid ul Adha 2026"
  eidDay1   DateTime @map("eid_day_1")               // calendar date of Day 1
  eidDay2   DateTime @map("eid_day_2")
  eidDay3   DateTime @map("eid_day_3")
  isActive  Boolean  @default(false) @map("is_active") // only ONE true at a time — enforced in app
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  animalPools        AnimalPool[]
  slaughterSchedules SlaughterSchedule[]
  dayPricing         DayPricing[]
  timeSlots          TimeSlot[]
  bookings           Booking[]

  @@map("years")
}

// ─────────────────────────────────────────────
// ANIMAL CONFIG — fixed Islamic rules per animal kind.
// Seeded once at setup. Never changed at runtime.
//
//  Kind        | Portions | Payas
//  ------------|----------|-------
//  GOAT        |    1     |   4
//  COW_MALE    |    7     |   4
//  COW_FEMALE  |    7     |   4
//  CAMEL       |   14     |   4
//
// payasPerAnimal is always 4 — Islamic rule, hardcoded.
// Each payas goes to one portion (first come first served).
// Portions beyond 4 in a cow/camel get no payas.
// ─────────────────────────────────────────────
model AnimalConfig {
  id                Int        @id @default(autoincrement())
  kind              AnimalKind @unique
  label             String                           // "Goat", "Male Cow", "Female Cow", "Camel"
  portionsPerAnimal Int        @map("portions_per_animal")  // 1 / 7 / 7 / 14
  payasPerAnimal    Int        @default(4) @map("payas_per_animal") // always 4
  description       String?    @db.Text

  animalPools        AnimalPool[]
  slaughterSchedules SlaughterSchedule[]
  dayPricing         DayPricing[]
  timeSlots          TimeSlot[]
  bookings           Booking[]

  @@map("animal_configs")
}

// ─────────────────────────────────────────────
// ANIMAL POOL — total stock per year per animal kind.
// Admin sets these totals once per year per kind.
// Computed totals stored for fast availability checks.
//
// APP RULE: sum of SlaughterSchedule.animalsCount across
// all days must equal totalAnimals for the same year+kind.
// This is validated in the service layer, not the DB.
// ─────────────────────────────────────────────
model AnimalPool {
  id            Int        @id @default(autoincrement())
  yearId        Int        @map("year_id")
  animalConfigId Int       @map("animal_config_id")
  totalAnimals  Int        @map("total_animals")    // e.g. 50 male cows
  totalPortions Int        @map("total_portions")   // totalAnimals × portionsPerAnimal
  totalPayas    Int        @map("total_payas")      // totalAnimals × 4
  notes         String?    @db.Text
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  year         Year         @relation(fields: [yearId], references: [id])
  animalConfig AnimalConfig @relation(fields: [animalConfigId], references: [id])

  @@unique([yearId, animalConfigId])
  @@map("animal_pools")
}

// ─────────────────────────────────────────────
// SLAUGHTER SCHEDULE — how many animals per kind per day.
// Admin sets: "Day 1 → 3 male cows, Day 2 → 4, Day 3 → 3"
// Sum across days must equal AnimalPool.totalAnimals.
// portionsCount & payasCount stored for quick slot calculations.
//
// APP RULE: sum of animalsCount across days must equal
// AnimalPool.totalAnimals for the same year+animalConfig.
// ─────────────────────────────────────────────
model SlaughterSchedule {
  id             Int      @id @default(autoincrement())
  yearId         Int      @map("year_id")
  animalConfigId Int      @map("animal_config_id")
  eidDay         EidDay   @map("eid_day")
  animalsCount   Int      @map("animals_count")   // e.g. 3 cows on Day 1
  portionsCount  Int      @map("portions_count")  // 3 × portionsPerAnimal
  payasCount     Int      @map("payas_count")     // 3 × 4 = 12
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  year         Year         @relation(fields: [yearId], references: [id])
  animalConfig AnimalConfig @relation(fields: [animalConfigId], references: [id])

  @@unique([yearId, animalConfigId, eidDay])
  @@map("slaughter_schedules")
}

// ─────────────────────────────────────────────
// DAY PRICING — price per portion per animal kind per Eid day.
// Admin sets once per year.
// payasExtraCharge: optional extra fee if customer wants payas.
// Set to 0 if payas are included free.
// ─────────────────────────────────────────────
model DayPricing {
  id               Int      @id @default(autoincrement())
  yearId           Int      @map("year_id")
  animalConfigId   Int      @map("animal_config_id")
  eidDay           EidDay   @map("eid_day")
  pricePerPortion  Decimal  @map("price_per_portion") @db.Decimal(12, 2)
  payasExtraCharge Decimal  @default(0) @map("payas_extra_charge") @db.Decimal(12, 2)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  year         Year         @relation(fields: [yearId], references: [id])
  animalConfig AnimalConfig @relation(fields: [animalConfigId], references: [id])
  bookings     Booking[]

  @@unique([yearId, animalConfigId, eidDay])
  @@map("day_pricing")
}

// ─────────────────────────────────────────────
// TIME SLOT — meat collection windows per animal kind per day.
//
// PAYAS LOGIC (corrected — 1 portion = 1 payas):
//   Admin assigns X animals to a slot.
//   totalPortions = X × portionsPerAnimal
//   totalPayas    = X × 4
//
//   When a booking is created with wantsPayas = true:
//     bookedPortions += portionsCount
//     bookedPayas    += portionsCount   ← NOT +1, but +portionsCount
//                                          because each portion gets 1 payas
//
//   APP RULE: bookedPayas + portionsCount must be ≤ totalPayas
//   before granting payas. Otherwise redirect to next slot with payas.
//
//   availablePortions = totalPortions - bookedPortions
//   availablePayas    = totalPayas    - bookedPayas
//
// APP RULE: animalsAssigned for a slot must not exceed
// SlaughterSchedule.animalsCount for the same day+kind.
// Validated in service layer.
// ─────────────────────────────────────────────
model TimeSlot {
  id              Int      @id @default(autoincrement())
  yearId          Int      @map("year_id")
  animalConfigId  Int      @map("animal_config_id")
  eidDay          EidDay   @map("eid_day")
  slotLabel       String   @map("slot_label")       // "9:00 PM – 10:00 PM"
  startTime       DateTime @map("start_time")
  endTime         DateTime @map("end_time")
  animalsAssigned Int      @map("animals_assigned")  // admin sets — drives totals below
  totalPortions   Int      @map("total_portions")    // animalsAssigned × portionsPerAnimal
  totalPayas      Int      @map("total_payas")       // animalsAssigned × 4
  bookedPortions  Int      @default(0) @map("booked_portions")
  bookedPayas     Int      @default(0) @map("booked_payas")   // increments by portionsCount per booking with payas
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  year         Year         @relation(fields: [yearId], references: [id])
  animalConfig AnimalConfig @relation(fields: [animalConfigId], references: [id])
  bookings     Booking[]

  @@map("time_slots")
}

// ─────────────────────────────────────────────
// CUSTOMER — reusable CRM record across years.
// CNIC is the unique national identifier (13 digits, Pakistan).
// ─────────────────────────────────────────────
model Customer {
  id        Int      @id @default(autoincrement())
  fullName  String   @map("full_name")
  phone     String
  cnic      String   @unique               // 13-digit national ID
  email     String?
  whatsapp  String?                        // may differ from phone
  address   String?  @db.Text
  city      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bookings Booking[]

  @@map("customers")
}

// ─────────────────────────────────────────────
// BOOKING — core transaction record.
//
// PAYAS FLOW:
//   1. Customer selects day + animal kind.
//   2. Front end shows all slots with availablePortions & availablePayas.
//   3. Customer picks a slot, enters portionsCount, ticks wantsPayas.
//   4. App checks: if wantsPayas, slot.bookedPayas + portionsCount ≤ slot.totalPayas
//   5. On confirmed booking:
//        slot.bookedPortions += portionsCount
//        if payasGranted: slot.bookedPayas += portionsCount
//   6. On cancellation: both counters are decremented.
//
// totalAmount = (portionsCount × pricePerPortion)
//             + (payasGranted ? portionsCount × payasExtraCharge : 0)
//
// hissaIdentifier: which hissa numbers this customer holds,
//   e.g. "5,6,7" for portions 5–7 of a cow. Assigned at booking time.
//   Useful for reconciliation and distribution verification.
//
// payasNote: explains payas outcome to customer or admin,
//   e.g. "Payas not available in selected slot — redirected to 10-11 PM"
// ─────────────────────────────────────────────
model Booking {
  id               Int           @id @default(autoincrement())
  bookingRef       String        @unique @map("booking_ref")       // "QRB-2026-00142"
  yearId           Int           @map("year_id")
  customerId       Int           @map("customer_id")
  animalConfigId   Int           @map("animal_config_id")
  eidDay           EidDay        @map("eid_day")
  timeSlotId       Int           @map("time_slot_id")
  dayPricingId     Int           @map("day_pricing_id")
  portionsCount    Int           @map("portions_count")            // number of hissa booked
  hissaIdentifier  String?       @map("hissa_identifier")          // e.g. "5,6,7" — which hissa numbers
  wantsPayas       Boolean       @default(false) @map("wants_payas")    // customer's request
  payasGranted     Boolean       @default(false) @map("payas_granted")  // confirmed at booking time
  payasNote        String?       @map("payas_note")                // reason if not granted or redirected
  totalAmount      Decimal       @map("total_amount") @db.Decimal(12, 2)
  masjidKeepsMeat  Boolean       @default(false) @map("masjid_keeps_meat") // customer donates meat back
  status           BookingStatus @default(PENDING)
  notes            String?       @db.Text
  bookedAt         DateTime      @default(now()) @map("booked_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  createdByAdmin   Boolean       @default(false) @map("created_by_admin")
  createdByAdminId Int?          @map("created_by_admin_id")

  year         Year         @relation(fields: [yearId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  animalConfig AnimalConfig @relation(fields: [animalConfigId], references: [id])
  timeSlot     TimeSlot     @relation(fields: [timeSlotId], references: [id])
  dayPricing   DayPricing   @relation(fields: [dayPricingId], references: [id])
  createdBy    Admin?       @relation("BookingCreatedBy", fields: [createdByAdminId], references: [id])

  payment       Payment?
  slip          BookingSlip?
  notifications Notification[]
  distribution  DistributionLog?

  @@map("bookings")
}

// ─────────────────────────────────────────────
// BOOKING SLIP — QR / barcode token for meat collection.
// Generated after payment is APPROVED.
// Staff scans this at the distribution point on Eid day.
// ─────────────────────────────────────────────
model BookingSlip {
  id          Int        @id @default(autoincrement())
  bookingId   Int        @unique @map("booking_id")
  slipCode    String     @unique @map("slip_code")    // value encoded in QR/barcode
  pdfUrl      String?    @map("pdf_url")              // link to generated PDF slip
  status      SlipStatus @default(VALID)
  generatedAt DateTime   @default(now()) @map("generated_at")
  usedAt      DateTime?  @map("used_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("booking_slips")
}

// ─────────────────────────────────────────────
// PAYMENT — one record per booking.
// Customer uploads proof → admin approves or rejects.
// Full audit trail kept in PaymentAttempt child table.
// ─────────────────────────────────────────────
model Payment {
  id             Int            @id @default(autoincrement())
  bookingId      Int            @unique @map("booking_id")
  amountDue      Decimal        @map("amount_due") @db.Decimal(12, 2)
  amountPaid     Decimal        @default(0) @map("amount_paid") @db.Decimal(12, 2)
  paymentMethod  PaymentMethod? @map("payment_method")
  transactionRef String?        @map("transaction_ref")   // bank TXN ID / Easypaisa ref
  receiptUrl     String?        @map("receipt_url")        // latest uploaded screenshot
  status         PaymentStatus  @default(UNPAID)
  approvedById   Int?           @map("approved_by_id")
  rejectionNote  String?        @map("rejection_note") @db.Text
  paidAt         DateTime?      @map("paid_at")
  approvedAt     DateTime?      @map("approved_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  booking    Booking          @relation(fields: [bookingId], references: [id])
  approvedBy Admin?           @relation("PaymentApprovedBy", fields: [approvedById], references: [id])
  attempts   PaymentAttempt[]

  @@map("payments")
}

// ─────────────────────────────────────────────
// PAYMENT ATTEMPT — audit trail for every upload/rejection cycle.
// Whenever a customer uploads a receipt (first time or after rejection),
// a new attempt record is created. This preserves the full history.
// ─────────────────────────────────────────────
model PaymentAttempt {
  id             Int            @id @default(autoincrement())
  paymentId      Int            @map("payment_id")
  attemptNumber  Int            @map("attempt_number")    // 1, 2, 3 ...
  receiptUrl     String         @map("receipt_url")        // screenshot uploaded this attempt
  transactionRef String?        @map("transaction_ref")
  paymentMethod  PaymentMethod? @map("payment_method")
  status         PaymentStatus  @default(SUBMITTED)        // SUBMITTED → APPROVED or REJECTED
  reviewedById   Int?           @map("reviewed_by_id")
  rejectionNote  String?        @map("rejection_note") @db.Text
  submittedAt    DateTime       @default(now()) @map("submitted_at")
  reviewedAt     DateTime?      @map("reviewed_at")

  payment    Payment @relation(fields: [paymentId], references: [id])
  reviewedBy Admin?  @relation("AttemptReviewedBy", fields: [reviewedById], references: [id])

  @@map("payment_attempts")
}

// ─────────────────────────────────────────────
// ADMIN — single masjid operator (no role tiers).
// ─────────────────────────────────────────────
model Admin {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String   // hashed (e.g. Argon2 in seed)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  approvedPayments  Payment[]         @relation("PaymentApprovedBy")
  reviewedAttempts  PaymentAttempt[]  @relation("AttemptReviewedBy")
  createdBookings   Booking[]         @relation("BookingCreatedBy")
  distributionLogs  DistributionLog[]

  @@map("admins")
}

// ─────────────────────────────────────────────
// NOTIFICATION — log of every message dispatched.
// One booking can have many notifications (confirmation + reminders).
// scheduledFor: when the job queue should send this — null means send immediately.
// payload: snapshot of message content at send time (for debugging/resend).
// ─────────────────────────────────────────────
model Notification {
  id           Int                 @id @default(autoincrement())
  bookingId    Int                 @map("booking_id")
  channel      NotificationChannel
  type         NotificationType
  status       NotificationStatus  @default(PENDING)
  scheduledFor DateTime?           @map("scheduled_for")   // null = immediate, set for EID_REMINDER / SLOT_REMINDER
  payload      Json?                                       // message snapshot at send time
  errorMsg     String?             @map("error_msg")
  sentAt       DateTime?           @map("sent_at")          // null until actually sent
  createdAt    DateTime            @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("notifications")
}

// ─────────────────────────────────────────────
// DISTRIBUTION LOG — what was physically handed over on Eid day.
// Staff scans the booking slip → this record is created.
// portionsGiven / payasGiven may differ from booking if partial handover.
// ─────────────────────────────────────────────
model DistributionLog {
  id            Int      @id @default(autoincrement())
  bookingId     Int      @unique @map("booking_id")
  adminId       Int      @map("admin_id")                   // staff who performed handover
  slipVerified  Boolean  @default(false) @map("slip_verified")   // QR scan confirmed
  meatGiven     Boolean  @default(true) @map("meat_given")
  portionsGiven Int      @map("portions_given")
  payasGiven    Boolean  @default(false) @map("payas_given")     // payas physically handed over
  remarks       String?  @db.Text
  distributedAt DateTime @default(now()) @map("distributed_at")

  booking Booking @relation(fields: [bookingId], references: [id])
  admin   Admin   @relation(fields: [adminId], references: [id])

  @@map("distribution_logs")
}
